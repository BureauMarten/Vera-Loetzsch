---
interface Props {
  title: string;
  teaser?: string;
  image?: string;
  date?: string;
  category?: string;
  href: string;
  author?: string;
  readingTime?: string;
}

const { title, teaser, image, date, category, href, author, readingTime } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString('de-DE', { day: '2-digit', month: 'long', year: 'numeric' })
  : undefined;
---

<article class="blog-card">
  <a href={href} class="card-link" tabindex="-1" aria-hidden="true">
    {image && (
      <div class="card-image">
        <img src={image} alt="" loading="lazy" />
      </div>
    )}
  </a>
  <div class="card-body">
    <div class="card-meta">
      {category && <span class="category">{category}</span>}
      {formattedDate && <time datetime={date} class="date">{formattedDate}</time>}
      {readingTime && <span class="reading-time">{readingTime}</span>}
    </div>
    <h3>
      <a href={href}>{title}</a>
    </h3>
    {teaser && <p class="teaser">{teaser}</p>}
    {author && <p class="author">{author}</p>}
  </div>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-background);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background-color: var(--color-surface-dark);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .card-image img { transform: scale(1.04); }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .category {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
  }

  .date, .reading-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .date::before { content: '·'; margin-right: 0.75rem; color: var(--color-border); }

  h3 {
    font-size: var(--text-lg);
    margin: 0;
    line-height: 1.3;
  }

  h3 a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  h3 a:hover { color: var(--color-primary-light); }

  .teaser {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin: 0;
    line-height: 1.6;
    flex: 1;
  }

  .author {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }
</style>
