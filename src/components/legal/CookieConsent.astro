---
/**
 * CookieConsent.astro
 *
 * WANN NUTZEN:
 * Sobald externe Dienste eingebunden sind:
 * - Leaflet / OpenStreetMap (Karten)
 * - Analytics (Plausible, Umami, GA)
 * - Externe Schriftarten via CDN
 * - Eingebettete Videos (YouTube, Vimeo)
 * - Sonstige externe Scripts
 *
 * Kategorien: Notwendig / Dienste / Analyse
 * Speichert dauerhaft in localStorage als JSON:
 * { necessary: true, services: bool, analytics: bool, date: string }
 *
 * Feuert Events:
 * - cookie-consent-services  → Maps, Videos, externe Embeds
 * - cookie-consent-analytics → Analytics, Tracking
 * - cookie-consent-all       → alle Kategorien
 *
 * Einstellungen nachträglich öffnen:
 * document.dispatchEvent(new CustomEvent('cookie-settings-open'))
 *
 * Für reine Info-Seiten ohne externe Dienste → CookieBanner.astro!
 */

interface Props {
  privacyHref?: string;
  imprintHref?: string;
}

const { privacyHref = '/datenschutz', imprintHref = '/impressum' } = Astro.props;
---

<div id="cookie-consent" role="dialog" aria-modal="true" aria-label="Cookie-Einstellungen" aria-live="polite" style="display:none">
  <div class="consent-inner">
    <div class="consent-text">
      <p class="consent-title">Cookie-Einstellungen</p>
      <p>
        Wir verwenden Cookies und externe Dienste. Wähle, was du erlauben möchtest.
        Mehr dazu in der <a href={privacyHref}>Datenschutzerklärung</a>.
      </p>
    </div>

    <div class="consent-categories">
      <div class="category">
        <div class="category-header">
          <span class="category-name">Notwendig</span>
          <span class="category-badge">Immer aktiv</span>
        </div>
        <p class="category-desc">Session-Daten, Cookie-Einstellungen. Ohne diese funktioniert die Website nicht.</p>
      </div>

      <div class="category">
        <div class="category-header">
          <label class="toggle-label" for="consent-toggle-services">
            <span class="category-name">Externe Dienste</span>
            <span class="toggle-wrapper">
              <input type="checkbox" id="consent-toggle-services" class="toggle-input" />
              <span class="toggle-track" aria-hidden="true"></span>
            </span>
          </label>
        </div>
        <p class="category-desc">Kartenanzeige (OpenStreetMap / Stadia Maps), eingebettete Inhalte.</p>
      </div>

      <div class="category">
        <div class="category-header">
          <label class="toggle-label" for="consent-toggle-analytics">
            <span class="category-name">Analyse & Marketing</span>
            <span class="toggle-wrapper">
              <input type="checkbox" id="consent-toggle-analytics" class="toggle-input" />
              <span class="toggle-track" aria-hidden="true"></span>
            </span>
          </label>
        </div>
        <p class="category-desc">Nutzungsstatistiken, Conversion-Tracking, Remarketing.</p>
      </div>
    </div>

    <div class="consent-actions">
      <button id="consent-necessary" class="btn-outline" type="button">Nur notwendige</button>
      <button id="consent-save" class="btn-outline" type="button">Auswahl speichern</button>
      <button id="consent-all" class="btn-primary" type="button">Alle akzeptieren</button>
    </div>

    <div class="consent-legal">
      <a href={imprintHref}>Impressum</a>
      <a href={privacyHref}>Datenschutz</a>
    </div>
  </div>
</div>

<!-- Einstellungen-Button — kann irgendwo auf der Seite platziert werden -->
<!-- Alternativ per JS: document.dispatchEvent(new CustomEvent('cookie-settings-open')) -->
<button id="cookie-settings-trigger" class="settings-trigger" type="button" aria-label="Cookie-Einstellungen öffnen" style="display:none">
  Cookie-Einstellungen
</button>

<style>
  #cookie-consent {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 3rem);
    max-width: 560px;
    z-index: 9999;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  .consent-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .consent-title {
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-primary);
    margin: 0 0 0.375rem;
  }

  .consent-text p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .consent-text a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Kategorien */
  .consent-categories {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .category {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .category:last-child {
    border-bottom: none;
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .toggle-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    cursor: pointer;
  }

  .category-name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .category-badge {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background-color: var(--color-surface-dark);
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
  }

  .category-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  /* Toggle Switch */
  .toggle-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .toggle-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-track {
    display: block;
    width: 36px;
    height: 20px;
    border-radius: var(--radius-full);
    background-color: var(--color-border);
    position: relative;
    transition: background-color var(--transition-fast);
  }

  .toggle-track::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: #fff;
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast);
  }

  .toggle-input:checked + .toggle-track {
    background-color: var(--color-primary);
  }

  .toggle-input:checked + .toggle-track::after {
    transform: translateX(16px);
  }

  .toggle-input:focus-visible + .toggle-track {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* Buttons */
  .consent-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .btn-primary, .btn-outline {
    flex: 1;
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
    white-space: nowrap;
    text-align: center;
  }

  .btn-primary {
    background-color: var(--color-primary);
    color: #fff;
    border: 1px solid var(--color-primary);
  }

  .btn-primary:hover { background-color: var(--color-primary-light); border-color: var(--color-primary-light); }

  .btn-outline {
    background-color: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-light);
  }

  .btn-outline:hover { border-color: var(--color-primary); color: var(--color-primary); }

  .consent-legal {
    display: flex;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .consent-legal a {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .consent-legal a:hover { color: var(--color-primary); }

  /* Einstellungs-Trigger */
  .settings-trigger {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.375rem 0.875rem;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    cursor: pointer;
    z-index: 9990;
    box-shadow: var(--shadow-sm);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .settings-trigger:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
</style>

<script>
  const banner    = document.getElementById('cookie-consent') as HTMLElement | null;
  const trigger   = document.getElementById('cookie-settings-trigger') as HTMLElement | null;
  const btnAll    = document.getElementById('consent-all');
  const btnSave   = document.getElementById('consent-save');
  const btnNec    = document.getElementById('consent-necessary');
  const togServices  = document.getElementById('consent-toggle-services') as HTMLInputElement | null;
  const togAnalytics = document.getElementById('consent-toggle-analytics') as HTMLInputElement | null;

  function getConsent() {
    try { return JSON.parse(localStorage.getItem('cookie_consent') ?? 'null'); } catch { return null; }
  }

  function saveConsent(services: boolean, analytics: boolean) {
    const data = {
      necessary: true,
      services,
      analytics,
      date: new Date().toISOString(),
    };
    localStorage.setItem('cookie_consent', JSON.stringify(data));
    hide();

    if (services)  document.dispatchEvent(new CustomEvent('cookie-consent-services'));
    if (analytics) document.dispatchEvent(new CustomEvent('cookie-consent-all'));
  }

  function hide() {
    if (banner)  banner.style.display  = 'none';
    if (trigger) trigger.style.display = 'block';
  }

  function open() {
    // Aktuelle Werte in Toggles laden
    const consent = getConsent();
    if (togServices)  togServices.checked  = consent?.services  ?? false;
    if (togAnalytics) togAnalytics.checked = consent?.analytics ?? false;
    if (banner)  banner.style.display  = 'block';
    if (trigger) trigger.style.display = 'none';
    banner?.querySelector<HTMLElement>('.btn-primary')?.focus();
  }

  // Init
  const existing = getConsent();
  if (!existing) {
    open();
  } else {
    if (trigger) trigger.style.display = 'block';
    // Bereits erteilte Consents erneut feuern (für dynamisch geladene Komponenten)
    if (existing.services)  document.dispatchEvent(new CustomEvent('cookie-consent-services'));
    if (existing.analytics) document.dispatchEvent(new CustomEvent('cookie-consent-all'));
  }

  btnAll?.addEventListener('click', () => saveConsent(true, true));
  btnNec?.addEventListener('click', () => saveConsent(false, false));
  btnSave?.addEventListener('click', () => saveConsent(
    togServices?.checked ?? false,
    togAnalytics?.checked ?? false,
  ));

  trigger?.addEventListener('click', open);

  // Von außen steuerbar: document.dispatchEvent(new CustomEvent('cookie-settings-open'))
  document.addEventListener('cookie-settings-open', open);
</script>
