---
interface Props {
  headline: string;
  text?: string;
  ctaLabel: string;
  ctaHref: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  background?: 'primary' | 'accent' | 'dark' | 'light';
  align?: 'left' | 'center';
}

const {
  headline,
  text,
  ctaLabel,
  ctaHref,
  ctaSecondaryLabel,
  ctaSecondaryHref,
  background = 'primary',
  align = 'center',
} = Astro.props;
---

<section class:list={['cta-section', `bg-${background}`, `align-${align}`]}>
  <div class="cta-inner">
    <div class="cta-content">
      <h2>{headline}</h2>
      {text && <p>{text}</p>}
    </div>
    <div class="cta-actions">
      <a href={ctaHref} class="btn-primary">{ctaLabel}</a>
      {ctaSecondaryLabel && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="btn-secondary">{ctaSecondaryLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--spacing-section) 1.5rem;
  }

  .bg-primary { background-color: var(--color-primary); color: #fff; }
  .bg-accent  { background-color: var(--color-accent);  color: #fff; }
  .bg-dark    { background-color: var(--color-primary-dark); color: #fff; }
  .bg-light   { background-color: var(--color-surface);  color: var(--color-text); }

  .cta-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .align-center .cta-inner {
    flex-direction: column;
    text-align: center;
    justify-content: center;
    max-width: var(--max-width-text);
  }

  .cta-content { flex: 1; }

  h2 {
    font-size: clamp(1.5rem, 3vw, var(--text-3xl));
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  p { font-size: var(--text-lg); opacity: 0.85; margin: 0; }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .align-center .cta-actions {
    justify-content: center;
  }

  .btn-primary {
    display: inline-block;
    background-color: #fff;
    color: var(--color-primary);
    font-weight: 700;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity var(--transition-fast);
    white-space: nowrap;
  }

  .bg-light .btn-primary {
    background-color: var(--color-primary);
    color: #fff;
  }

  .btn-primary:hover { opacity: 0.85; color: var(--color-primary); }
  .bg-light .btn-primary:hover { color: #fff; }

  .btn-secondary {
    display: inline-block;
    background-color: transparent;
    color: #fff;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    border: 2px solid rgba(255,255,255,0.5);
    text-decoration: none;
    transition: border-color var(--transition-fast);
    white-space: nowrap;
  }

  .btn-secondary:hover { border-color: #fff; color: #fff; }

  .bg-light .btn-secondary {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  @media (max-width: 480px) {
    .cta-actions { flex-direction: column; width: 100%; }
    .btn-primary, .btn-secondary { text-align: center; }
  }
</style>
