---
interface Slide {
  headline: string;
  subline?: string;
  ctaLabel: string;
  ctaHref: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  backgroundImage?: string;
  overlay?: boolean;
}

interface Props {
  slides: Slide[];
  autoplay?: boolean;
  autoplayInterval?: number;
  showDots?: boolean;
  showArrows?: boolean;
  ariaLabel?: string;
  ariaPrevLabel?: string;
  ariaNextLabel?: string;
  ariaDotLabel?: (index: number) => string;
}

const {
  slides,
  autoplay = true,
  autoplayInterval = 5000,
  showDots = true,
  showArrows = true,
  ariaLabel = 'Bild-Slider',
  ariaPrevLabel = 'Vorheriger Slide',
  ariaNextLabel = 'Nächster Slide',
  ariaDotLabel = (i) => `Slide ${i + 1} von ${slides.length}`,
} = Astro.props;
---

<section class="hero-slider" data-autoplay={autoplay} data-interval={autoplayInterval} aria-label={ariaLabel} aria-roledescription="Slider">
  <div class="hero-track">
    {slides.map((slide) => (
      <div
        class="hero-slide"
        style={slide.backgroundImage ? `background-image: url('${slide.backgroundImage}')` : undefined}
      >
        {(slide.overlay ?? true) && slide.backgroundImage && <div class="slide-overlay" />}
        <div class="slide-content">
          <h2>{slide.headline}</h2>
          {slide.subline && <p class="subline">{slide.subline}</p>}
          <div class="slide-ctas">
            <a href={slide.ctaHref} class="btn-primary">{slide.ctaLabel}</a>
            {slide.ctaSecondaryLabel && slide.ctaSecondaryHref && (
              <a href={slide.ctaSecondaryHref} class="btn-secondary">{slide.ctaSecondaryLabel}</a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  {showArrows && (
    <div class="hero-arrows">
      <button class="arrow arrow-prev" aria-label={ariaPrevLabel}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <button class="arrow arrow-next" aria-label={ariaNextLabel}>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>
  )}

  {showDots && (
    <div class="hero-dots" role="tablist" aria-label="Slide-Navigation">
      {slides.map((_, i) => (
        <button
          class:list={['dot', { active: i === 0 }]}
          role="tab"
          aria-label={ariaDotLabel(i)}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-index={i}
        />
      ))}
    </div>
  )}
</section>

<style>
  .hero-slider {
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    background-color: var(--color-primary);
  }

  .hero-track {
    display: flex;
    height: 100%;
    min-height: 100svh;
    transition: transform 1400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .hero-track.no-transition {
    transition: none;
  }

  .hero-slide {
    min-width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary);
    background-size: cover;
    background-position: center;
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.45);
    z-index: 0;
  }

  .slide-content {
    position: relative;
    z-index: 1;
    max-width: var(--max-width-text);
    color: #fff;
  }

  h2 {
    font-size: clamp(2rem, 5vw, var(--text-5xl));
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .subline {
    font-size: var(--text-xl);
    opacity: 0.9;
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  .slide-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .slide-ctas {
      flex-direction: column;
      align-items: stretch;
    }

    .btn-primary,
    .btn-secondary {
      text-align: center;
    }
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--color-accent);
    color: #fff;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .btn-primary:hover {
    opacity: 0.85;
    color: #fff;
  }

  .btn-secondary {
    display: inline-block;
    background-color: transparent;
    color: #fff;
    font-weight: 600;
    padding: 0.875rem 2rem;
    border-radius: var(--radius-sm);
    border: 2px solid rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .btn-secondary:hover {
    border-color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  /* Pfeile */
  .hero-arrows {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    pointer-events: none;
    z-index: 2;
  }

  .arrow {
    pointer-events: auto;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #fff;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background var(--transition-fast);
    backdrop-filter: blur(4px);
  }

  .arrow:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  /* Dots */
  .hero-dots {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 2;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .dot.active {
    background: #fff;
    transform: scale(1.3);
  }
</style>

<script>
  const sliders = document.querySelectorAll<HTMLElement>('.hero-slider');

  sliders.forEach((slider) => {
    const track = slider.querySelector<HTMLElement>('.hero-track')!;
    const dots = slider.querySelectorAll<HTMLButtonElement>('.dot');
    const prevBtn = slider.querySelector<HTMLButtonElement>('.arrow-prev');
    const nextBtn = slider.querySelector<HTMLButtonElement>('.arrow-next');
    const autoplay = slider.dataset.autoplay !== 'false';
    const interval = parseInt(slider.dataset.interval ?? '5000');

    const slides = Array.from(track.children) as HTMLElement[];
    const total = slides.length;
    if (total < 2) return;

    // Klone für Infinite Loop
    const firstClone = slides[0].cloneNode(true) as HTMLElement;
    const lastClone = slides[total - 1].cloneNode(true) as HTMLElement;
    track.appendChild(firstClone);
    track.insertBefore(lastClone, slides[0]);

    let current = 1; // 0 = lastClone, 1..N = echte Slides, N+1 = firstClone
    let isTransitioning = false;

    function goTo(index: number, animated = true) {
      if (!animated) track.classList.add('no-transition');
      track.style.transform = `translateX(-${index * 100}%)`;
      if (!animated) {
        // Reflow erzwingen damit no-transition greift
        track.getBoundingClientRect();
        track.classList.remove('no-transition');
      }
      current = index;
      updateDots();
    }

    function updateDots() {
      // Dot-Index: current - 1 (wegen lastClone vorne), wrap
      const dotIndex = ((current - 1) + total) % total;
      dots.forEach((d, i) => {
        d.classList.toggle('active', i === dotIndex);
        d.setAttribute('aria-selected', i === dotIndex ? 'true' : 'false');
      });
    }

    function next() {
      if (isTransitioning) return;
      isTransitioning = true;
      goTo(current + 1);
    }

    function prev() {
      if (isTransitioning) return;
      isTransitioning = true;
      goTo(current - 1);
    }

    // Infinite-Loop-Sprung nach Transition
    track.addEventListener('transitionend', (e) => {
      if (e.target !== track) return;
      if (current === total + 1) goTo(1, false);
      if (current === 0) goTo(total, false);
      isTransitioning = false;
    });

    // Start
    goTo(1, false);

    // Controls
    nextBtn?.addEventListener('click', next);
    prevBtn?.addEventListener('click', prev);

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const i = parseInt(dot.dataset.index ?? '0');
        if (isTransitioning) return;
        isTransitioning = true;
        goTo(i + 1);
      });
    });

    // Autoplay
    if (autoplay) {
      let timer = setInterval(next, interval);
      slider.addEventListener('mouseenter', () => clearInterval(timer));
      slider.addEventListener('mouseleave', () => { timer = setInterval(next, interval); });
    }

    // Touch/Swipe
    let touchStartX = 0;
    slider.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    slider.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) diff > 0 ? next() : prev();
    });
  });
</script>
