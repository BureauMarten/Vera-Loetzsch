---
interface PricingTier {
  name: string;
  price: string;
  period?: string;
  description?: string;
  features: string[];
  ctaLabel: string;
  ctaHref: string;
  highlighted?: boolean;
  badge?: string;
}

interface Props {
  tiers: PricingTier[];
  currency?: string;
}

const { tiers, currency = '€' } = Astro.props;
---

<section class="pricing-section">
  <div class="pricing-grid" style={`--tier-count: ${tiers.length}`}>
    {tiers.map((tier) => (
      <div class:list={['pricing-card', { highlighted: tier.highlighted }]}>
        {tier.badge && <span class="badge">{tier.badge}</span>}
        <div class="tier-header">
          <p class="tier-name">{tier.name}</p>
          <p class="tier-price">
            <span class="currency">{currency}</span>
            <span class="amount">{tier.price}</span>
            {tier.period && <span class="period">/{tier.period}</span>}
          </p>
          {tier.description && <p class="tier-description">{tier.description}</p>}
        </div>
        <ul class="feature-list">
          {tier.features.map((feature) => (
            <li>
              <span class="check" aria-hidden="true">✓</span>
              {feature}
            </li>
          ))}
        </ul>
        <a href={tier.ctaHref} class:list={['cta', { 'cta-primary': tier.highlighted, 'cta-outline': !tier.highlighted }]}>
          {tier.ctaLabel}
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  .pricing-section {
    padding: var(--spacing-section) 1.5rem;
    background-color: var(--color-surface);
  }

  .pricing-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(var(--tier-count), 1fr);
    gap: 1.5rem;
    align-items: stretch; /* gleiche Höhe */
  }

  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }

  .pricing-card {
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  /* CTA immer am unteren Rand */
  .pricing-card .cta {
    margin-top: auto;
  }

  .pricing-card.highlighted {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-accent);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 700;
    padding: 0.25rem 0.875rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .tier-name {
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }

  .tier-price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .currency {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-primary);
  }

  .amount {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary);
  }

  .period {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .tier-description {
    margin: 0.5rem 0 0;
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.5;
  }

  .check {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  .cta {
    display: block;
    text-align: center;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: var(--text-base);
    text-decoration: none;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
  }

  .cta-primary {
    background-color: var(--color-primary);
    color: #fff;
  }

  .cta-primary:hover { background-color: var(--color-primary-light); color: #fff; }

  .cta-outline {
    border: 2px solid var(--color-border);
    color: var(--color-primary);
  }

  .cta-outline:hover { border-color: var(--color-primary); }
</style>
