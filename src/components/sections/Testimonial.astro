---
interface TestimonialItem {
  quote: string;
  name: string;
  role?: string;
  company?: string;
  image?: string;
  rating?: 1 | 2 | 3 | 4 | 5;
}

interface Props {
  items: TestimonialItem[];
  columns?: 1 | 2 | 3;
  background?: 'light' | 'dark' | 'primary';
}

const { items, columns = 3, background = 'light' } = Astro.props;
---

<section class={`testimonial-section bg-${background}`}>
  <div class="testimonial-grid" style={`--columns: ${columns}`}>
    {items.map((item) => (
      <div class="testimonial-card">
        {item.rating && (
          <div class="stars" aria-label={`${item.rating} von 5 Sternen`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={['star', { filled: i < item.rating! }]}>★</span>
            ))}
          </div>
        )}
        <blockquote>
          <p>»{item.quote}«</p>
        </blockquote>
        <footer class="testimonial-author">
          {item.image && (
            <img src={item.image} alt={item.name} class="author-image" loading="lazy" />
          )}
          <div>
            <p class="author-name">{item.name}</p>
            {(item.role || item.company) && (
              <p class="author-meta">
                {item.role}{item.role && item.company && ', '}{item.company}
              </p>
            )}
          </div>
        </footer>
      </div>
    ))}
  </div>
</section>

<style>
  .testimonial-section {
    padding: var(--spacing-section) 1.5rem;
  }

  .bg-light   { background-color: var(--color-surface); }
  .bg-dark    { background-color: var(--color-primary-dark); }
  .bg-primary { background-color: var(--color-primary); }

  .testimonial-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(var(--columns), 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .testimonial-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .testimonial-grid { grid-template-columns: 1fr; }
  }

  .testimonial-card {
    background-color: var(--color-background);
    border-radius: var(--radius-md);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .bg-dark .testimonial-card,
  .bg-primary .testimonial-card {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .stars { display: flex; gap: 2px; }

  .star { font-size: 1rem; color: var(--color-border); }
  .star.filled { color: var(--color-accent); }

  blockquote { margin: 0; flex: 1; }

  blockquote p {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
    font-style: italic;
  }

  .bg-dark blockquote p,
  .bg-primary blockquote p { color: rgba(255,255,255,0.9); }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .bg-dark .testimonial-author,
  .bg-primary .testimonial-author { border-color: rgba(255,255,255,0.15); }

  .author-image {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .author-name {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  .bg-dark .author-name,
  .bg-primary .author-name { color: #fff; }

  .author-meta {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .bg-dark .author-meta,
  .bg-primary .author-meta { color: rgba(255,255,255,0.5); }
</style>
