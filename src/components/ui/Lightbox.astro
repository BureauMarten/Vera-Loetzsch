---
// Lightbox — wird in Projektseiten eingebunden.
// Voraussetzung: .galerie img Elemente haben data-index gesetzt.
---

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Bildansicht" hidden>
  <button id="lb-close" aria-label="Schließen">✕</button>
  <button id="lb-prev" aria-label="Vorheriges Bild">&#8249;</button>
  <button id="lb-next" aria-label="Nächstes Bild">&#8250;</button>
  <div id="lb-img-wrap">
    <img id="lb-img" src="" alt="" />
  </div>
  <p id="lb-counter"></p>
</div>

<style>
  #lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lightbox[hidden] {
    display: none;
  }

  #lb-img-wrap {
    max-width: 90vw;
    max-height: 88vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #lb-img {
    max-width: 90vw;
    max-height: 88vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    display: block;
    user-select: none;
  }

  #lb-close {
    position: fixed;
    top: 1.25rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: #fff;
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
    transition: opacity var(--transition-fast);
    z-index: 10001;
  }

  #lb-close:hover { opacity: 1; }

  #lb-prev,
  #lb-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-size: 2.5rem;
    line-height: 1;
    width: 3rem;
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
    z-index: 10001;
  }

  #lb-prev { left: 1rem; }
  #lb-next { right: 1rem; }

  #lb-prev:hover,
  #lb-next:hover {
    background: rgba(255,255,255,0.22);
  }

  #lb-prev:disabled,
  #lb-next:disabled {
    opacity: 0.2;
    cursor: default;
  }

  #lb-counter {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    font-size: var(--text-sm);
    margin: 0;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const img      = document.getElementById('lb-img') as HTMLImageElement;
  const counter  = document.getElementById('lb-counter')!;
  const btnClose = document.getElementById('lb-close')!;
  const btnPrev  = document.getElementById('lb-prev') as HTMLButtonElement;
  const btnNext  = document.getElementById('lb-next') as HTMLButtonElement;

  // Alle Galeriebilder einsammeln
  const thumbs = Array.from(
    document.querySelectorAll<HTMLImageElement>('.galerie img')
  );

  let current = 0;

  function show(index: number) {
    current = index;
    const t = thumbs[current];
    // srcset enthält das hochauflösende WebP — erstes Element nehmen
    const src = t.currentSrc || t.src;
    img.src = src;
    img.alt = t.alt;
    counter.textContent = `${current + 1} / ${thumbs.length}`;
    btnPrev.disabled = current === 0;
    btnNext.disabled = current === thumbs.length - 1;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    btnClose.focus();
  }

  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    thumbs[current]?.focus();
  }

  // Klick auf Galeriebild
  thumbs.forEach((t, i) => {
    t.style.cursor = 'zoom-in';
    t.setAttribute('tabindex', '0');
    t.addEventListener('click', () => show(i));
    t.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); show(i); }
    });
  });

  btnClose.addEventListener('click', close);
  btnPrev.addEventListener('click', () => show(current - 1));
  btnNext.addEventListener('click', () => show(current + 1));

  // Klick auf Hintergrund schließt
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) close();
  });

  // Tastatursteuerung
  document.addEventListener('keydown', (e) => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft'  && current > 0)                  show(current - 1);
    if (e.key === 'ArrowRight' && current < thumbs.length - 1)  show(current + 1);
  });
</script>
