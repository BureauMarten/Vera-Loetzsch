---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';

const posts = [
  {
    slug: 'was-machen-eigentlich-theatermalerinnen',
    titel: 'Was machen eigentlich Theatermaler*innen?',
    bild: '/images/9-4.jpg',
    bildAlt: 'Theatermalerei – Bühnenmalerei',
    tags: ['Bühnenbild', 'Bühnenmalerei', 'Kulissenmalerei', 'Theatermalerei'],
  },
  {
    slug: 'wie-werde-ich-theatermalerin',
    titel: 'Wie werde ich Theatermaler*in?',
    bild: '/images/10-2.jpg',
    bildAlt: 'Theatermaler*in – Ausbildung und Studium',
    tags: ['Bühnenmaler Ausbildung', 'HfBK Dresden', 'Szenische Malerei', 'Theatermaler'],
  },
];
---

<BaseLayout
  title="Blog – Vera Lötzsch"
  description="Blog von Vera Lötzsch über Theatermalerei, Bühnenmalerei und den Beruf der Theatermaler*in."
>
  <PageHeader
    title="Blog"
    breadcrumb={[{ label: 'Blog', href: '/blog' }]}
  />

  <div class="content">
    <div class="post-grid">
      {posts.map(p => (
        <a href={`/blog/${p.slug}`} class="post-card">
          <div class="img-wrap">
            <img src={p.bild} alt={p.bildAlt} loading="lazy" />
          </div>
          <div class="post-info">
            <div class="tags">
              {p.tags.slice(0, 3).map(t => (
                <span class="tag">{t}</span>
              ))}
            </div>
            <h2>{p.titel}</h2>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem var(--spacing-section);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    transition: box-shadow var(--transition-normal);
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
  }

  .img-wrap {
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-normal);
  }

  .post-card:hover .img-wrap img {
    transform: scale(1.03);
  }

  .post-info {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    background: rgba(50, 74, 109, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  h2 {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
