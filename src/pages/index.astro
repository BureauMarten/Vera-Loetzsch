---
import BaseLayout from '../layouts/BaseLayout.astro';

const slides = [
  {
    src: '/images/Einzelbilder-web-04.jpg',
    alt: 'Bühnenmalerei – Theaterarbeit',
    caption: '',
  },
  {
    src: '/images/Vera_3.jpeg',
    alt: 'Vera Lötzsch bei der Arbeit',
    caption: '',
  },
  {
    src: '/images/Vera_2.jpeg',
    alt: 'Vera Lötzsch',
    caption: '',
  },
  {
    src: '/images/Die-Czardasfuerstin-Freiberg-web-03.jpg',
    alt: 'Die Czardasfürstin – Seebühne Kriebstein',
    caption: 'Seebühne Kriebstein, Mittelsächsiches Theater Freiberg-Döbeln',
  },
  {
    src: '/images/Courbet_Kopie-web.jpg',
    alt: 'Gemäldekopie nach Gustave Courbet',
    caption: 'Gemäldekopie Gustave Courbet — Foto: Reiner Eckel, Zeitz',
  },
  {
    src: '/images/Fassade-Zeitz-web-01.jpg',
    alt: 'Die Tänzerin – Fassadenmalerei Zeitz',
    caption: '',
  },
];
---

<BaseLayout
  title="Vera Lötzsch – Bühnen- & Theatermalerin"
  description="Freiberufliche Bühnen- und Theatermalerin aus Leipzig. Theatermalerei, Fassadenmalerei, Wandmalerei und Gemäldekopien."
>
  <!-- Slider -->
  <section class="slider" id="slider" aria-label="Portfolio-Slideshow">
    <div class="slides-track" id="slides-track">
      {slides.map((s, i) => (
        <div class="slide" aria-hidden={i !== 0 ? 'true' : 'false'}>
          <img src={s.src} alt={s.alt} loading={i === 0 ? 'eager' : 'lazy'} />
          {s.caption && (
            <p class="slide-caption">{s.caption}</p>
          )}
        </div>
      ))}
    </div>

    <!-- Dots -->
    <div class="slider-dots" role="tablist" aria-label="Slideshow-Navigation">
      {slides.map((_, i) => (
        <button
          class:list={['dot', { active: i === 0 }]}
          data-index={i}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-label={`Slide ${i + 1}`}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* Kein padding-top für Startseite — Slider geht bis ganz oben */
  main {
    padding-top: 0 !important;
  }

  .slider {
    position: relative;
    width: 100%;
    height: 600px;
    overflow: hidden;
    background: var(--color-primary);
  }

  .slides-track {
    display: flex;
    height: 100%;
    transition: transform 1200ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slide-caption {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    font-size: 0.75rem;
    font-weight: 300;
    color: rgba(255,255,255,0.75);
    margin: 0;
    text-align: right;
  }

  .slider-dots {
    position: absolute;
    bottom: 1.25rem;
    right: 1.5rem;
    display: flex;
    gap: 6px;
    z-index: 10;
  }

  /* Wenn Caption vorhanden, Dots links positionieren */
  .slider-dots {
    bottom: 1.25rem;
    left: 1.5rem;
    right: auto;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background-color: #C8D5DC;
    padding: 0;
    transition: background-color 200ms ease;
  }

  .dot.active {
    background-color: #324A6D;
  }

  @media (max-width: 1024px) {
    .slider { height: 500px; }
  }

  @media (max-width: 767px) {
    .slider { height: 400px; }
    .slide-caption { font-size: 0.6875rem; }
  }
</style>

<script>
  const track = document.getElementById('slides-track') as HTMLElement | null;
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides[current]?.setAttribute('aria-hidden', 'true');
    dots[current]?.classList.remove('active');
    dots[current]?.setAttribute('aria-selected', 'false');

    current = idx;

    if (track) track.style.transform = `translateX(-${current * 100}%)`;
    slides[current]?.setAttribute('aria-hidden', 'false');
    dots[current]?.classList.add('active');
    dots[current]?.setAttribute('aria-selected', 'true');
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function startTimer() {
    timer = setInterval(next, 4000);
  }

  function resetTimer() {
    clearInterval(timer);
    startTimer();
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      goTo(i);
      resetTimer();
    });
  });

  startTimer();

  // Pause on hover
  const slider = document.getElementById('slider');
  slider?.addEventListener('mouseenter', () => clearInterval(timer));
  slider?.addEventListener('mouseleave', startTimer);
</script>
