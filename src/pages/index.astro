---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import imgEinzelbilder from '../assets/images/Einzelbilder-web-04.jpg';
import imgVera3 from '../assets/images/Vera_3.jpeg';
import imgVera2 from '../assets/images/Vera_2.jpeg';
import imgCzardasfuerstin from '../assets/images/Die-Czardasfuerstin-Freiberg-web-03.jpg';
import imgCourbet from '../assets/images/Courbet_Kopie-web.jpg';
import imgFassadeZeitz from '../assets/images/Fassade-Zeitz-web-01.jpg';

const slides = [
  {
    src: imgEinzelbilder,
    alt: 'Bühnenmalerei – Theaterarbeit',
    credit: 'Mittelsächsisches Theater Freiberg-Döbeln',
    
  },
  {
    src: imgVera3,
    alt: 'Blick auf das Bühnenbild der Störtebecker Festspile 2024',
    credit: 'Foto: Privat',
    href: '/projekte/stoertebeker-festspiele-2024',
    label: 'Störtebeker Festspiele 2024',
  },
  {
    src: imgVera2,
    alt: 'Vera Lötzsch',
    credit: 'Foto: privat',
    href:'/projekte/stoertebeker-festspiele-2024',
    label: 'Störtebeker Festspiele 2024'

  },
  {
    src: imgCzardasfuerstin,
    alt: 'Die Czardasfürstin – Seebühne Kriebstein',
    credit: 'Seebühne Kriebstein, Mittelsächsisches Theater Freiberg-Döbeln',
    href: '/projekte/die-czardasfuerstin',
    label: 'Zum Projekt',
  },
  {
    src: imgCourbet,
    alt: 'Gemäldekopie nach Gustave Courbet',
    credit: 'Foto: Privat',
    href: '/projekte/der-verzweifelte-gustave-courbet',
    label: 'Zum Projekt',
  },
  {
    src: imgFassadeZeitz,
    alt: 'Die Tänzerin – Fassadenmalerei Zeitz',
    credit: 'Foto: Reiner Eckel, Zeitz',
    href: '/projekte/die-taenzerin',
    label: 'Zum Projekt',
  },
];
---

<BaseLayout
  title="Vera Lötzsch – Bühnen- & Theatermalerin"
  description="Freiberufliche Bühnen- und Theatermalerin. Theatermalerei, Fassadenmalerei, Wandmalerei und Gemäldekopien."
>
  <div class="slider-wrapper">
    <div class="slider" id="slider">
      <div class="track" id="track">
        {slides.map((s) => (
          <div class="slide">
            <Image src={s.src} alt={s.alt} loading="lazy" />
            {s.credit && (
              <p class="slide-credit">{s.credit}</p>
            )}
            {s.href && <a href={s.href} class="slide-btn">{s.label} →</a>}
          </div>
        ))}
      </div>

      <!-- Pfeile -->
      <button class="arrow arrow-prev" aria-label="Vorheriger Slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="arrow arrow-next" aria-label="Nächster Slide">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <!-- Dots -->
      <div class="dots" role="tablist">
        {slides.map((_, i) => (
          <button
            class:list={['dot', { active: i === 0 }]}
            data-index={i}
            role="tab"
            aria-label={`Slide ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .slider-wrapper {
    --slider-height: 600px;
    flex: 1;
    display: flex;
    align-items: center;
    padding: 2rem var(--padding-x);
  }

  .slider {
    position: relative;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    height: var(--slider-height);
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color-primary);
  }

  .track {
    display: flex;
    height: 100%;
    transition: transform 1400ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .track.no-transition {
    transition: none;
  }

  .slide {
    flex: 0 0 100%;
    height: 100%;
    position: relative;
  }

  .slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Credit oben rechts */
  .slide-credit {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.6875rem;
    font-weight: 300;
    color: rgba(255,255,255,0.85);
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
    margin: 0;
    line-height: 1.4;
  }

  /* Button unten rechts */
  .slide-btn {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #fff;
    background: rgba(28, 36, 75, 0.65);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.25);
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 150ms ease, border-color 150ms ease;
    white-space: nowrap;
  }

  .slide-btn:hover {
    background: rgba(28, 36, 75, 0.9);
    border-color: rgba(255,255,255,0.5);
    color: #fff;
  }

  /* Pfeile */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: background 150ms ease;
    z-index: 10;
  }

  .arrow:hover { background: rgba(255,255,255,0.3); }
  .arrow-prev { left: 1rem; }
  .arrow-next { right: 1rem; }

  /* Dots */
  .dots {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    display: flex;
    gap: 6px;
    z-index: 10;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: #C8D5DC;
    cursor: pointer;
    padding: 0;
    transition: background 200ms ease;
  }

  .dot.active { background: #324A6D; }

  @media (max-width: 1024px) {
    .slider-wrapper { --slider-height: 500px; }
  }

  @media (max-width: 767px) {
    .slider-wrapper { --slider-height: 400px; }
    .slide-btn { font-size: 0.6875rem; padding: 0.3rem 0.625rem; }
  }
</style>

<script>
  const track = document.getElementById('track') as HTMLElement;
  const slider = document.getElementById('slider') as HTMLElement;
  const slides = Array.from(track.children) as HTMLElement[];
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const total = slides.length;

  // Klone für Infinite Loop
  const firstClone = slides[0].cloneNode(true) as HTMLElement;
  const lastClone = slides[total - 1].cloneNode(true) as HTMLElement;
  track.appendChild(firstClone);
  track.insertBefore(lastClone, slides[0]);

  let current = 1;
  let isTransitioning = false;

  function goTo(index: number, animated = true) {
    if (!animated) track.classList.add('no-transition');
    track.style.transform = `translateX(-${index * 100}%)`;
    if (!animated) {
      track.getBoundingClientRect();
      track.classList.remove('no-transition');
    }
    current = index;
    const dotIndex = ((current - 1) + total) % total;
    dots.forEach((d, i) => {
      d.classList.toggle('active', i === dotIndex);
      d.setAttribute('aria-selected', i === dotIndex ? 'true' : 'false');
    });
  }

  track.addEventListener('transitionend', (e) => {
    if (e.target !== track) return;
    if (current === total + 1) goTo(1, false);
    if (current === 0) goTo(total, false);
    isTransitioning = false;
  });

  function next() {
    if (isTransitioning) return;
    isTransitioning = true;
    goTo(current + 1);
  }

  function prev() {
    if (isTransitioning) return;
    isTransitioning = true;
    goTo(current - 1);
  }

  goTo(1, false);

  document.querySelector('.arrow-prev')?.addEventListener('click', prev);
  document.querySelector('.arrow-next')?.addEventListener('click', next);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      if (isTransitioning) return;
      isTransitioning = true;
      goTo(i + 1);
    });
  });

  // Autoplay
  let timer = setInterval(next, 5000);
  slider.addEventListener('mouseenter', () => clearInterval(timer));
  slider.addEventListener('mouseleave', () => { timer = setInterval(next, 5000); });

  // Touch/Swipe
  let touchStartX = 0;
  slider.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
  slider.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) diff > 0 ? next() : prev();
  });
</script>
