---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/layout/PageHeader.astro';
---

<BaseLayout
  title="Kontakt – Vera Lötzsch"
  description="Kontaktformular und Kontaktdaten von Vera Lötzsch, freiberufliche Bühnen- und Theatermalerin."
>
  <PageHeader
    title="Sprechen Sie mich an"
    breadcrumb={[{ label: 'Kontakt', href: '/kontakt' }]}
  />

  <div class="content">
    <div class="contact-info">
      <p>
        Sie möchten ein Projekt besprechen oder haben Fragen zu meinen Leistungen?
        Schreiben Sie mir gerne über das Formular oder direkt per E-Mail.
      </p>
      <p>
        <strong>Instagram:</strong>
        <a href="https://www.instagram.com/loevenkind" target="_blank" rel="noopener noreferrer">@loevenkind</a>
      </p>
      <p>
        <strong>E-Mail:</strong>
        <a href="mailto:kontakt@vera-loetzsch.de">kontakt@vera-loetzsch.de</a>
      </p>
    </div>

    <form class="contact-form" name="kontakt" method="POST" netlify>
      <div class="field">
        <label for="name">Name <span aria-hidden="true">*</span></label>
        <input type="text" id="name" name="name" required autocomplete="name" />
      </div>

      <div class="field">
        <label for="email">E-Mail <span aria-hidden="true">*</span></label>
        <input type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label for="betreff">Betreff <span aria-hidden="true">*</span></label>
        <input type="text" id="betreff" name="betreff" required />
      </div>

      <div class="field">
        <label for="nachricht">Nachricht <span aria-hidden="true">*</span></label>
        <textarea id="nachricht" name="nachricht" rows="6" required></textarea>
      </div>

      <div class="field consent">
        <label class="checkbox-label">
          <input type="checkbox" name="datenschutz" required />
          <span>Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> zur Kenntnis genommen und stimme der Verarbeitung meiner Daten zur Beantwortung meiner Anfrage zu.</span>
        </label>
      </div>

      <button type="submit" class="btn">Nachricht senden</button>
    </form>
  </div>
</BaseLayout>

<style>
  .content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-section) 1.5rem;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-info p {
    margin: 0 0 1.25rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .contact-info a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .contact-info a:hover {
    text-decoration: underline;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  label span[aria-hidden] {
    color: var(--color-accent);
  }

  input,
  textarea {
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-background);
    transition: border-color var(--transition-fast);
    width: 100%;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  textarea {
    resize: vertical;
  }

  .consent {
    margin-top: 0.5rem;
  }

  .checkbox-label {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-light);
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: auto;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .checkbox-label a {
    color: var(--color-primary);
  }

  .btn {
    display: inline-block;
    background-color: var(--color-primary);
    color: #fff;
    padding: 0.875rem 2.5rem;
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background-color var(--transition-fast);
    align-self: flex-start;
  }

  .btn:hover {
    background-color: var(--color-primary-dark);
  }

  @media (max-width: 768px) {
    .content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
