---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import { Image } from 'astro:assets';
import imgDon1 from '../../assets/images/Einzelbilder-web-08.jpg';
import imgDon2 from '../../assets/images/IMG-20220515-WA0004.jpg';
---

<BaseLayout
  title="Don Pasquale – Vera Lötzsch"
  description="Malerische und plastische Bühnenbildgestaltung für die Oper Don Pasquale von Donizetti am Mittelsächsischen Theater Freiberg-Döbeln, 2021."
>
  <PageHeader
    title="Don Pasquale"
    breadcrumb={[
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Don Pasquale', href: '/projekte/don-pasquale' },
    ]}
  />

  <div class="projekt-content">
    <div class="meta">
      <dl>
        <dt>Kategorie</dt>
        <dd>Theater &amp; Bühnen</dd>
        <dt>Institution</dt>
        <dd>Mittelsächsisches Theater Freiberg-Döbeln</dd>
        <dt>Bühnenbildentwurf</dt>
        <dd>Wolfgang Clausnitzer</dd>
        <dt>Fotos</dt>
        <dd>Privatarchiv</dd>
        <dt>Jahr</dt>
        <dd>2021</dd>
      </dl>
      <p>Malerische und plastische Bühnenbildgestaltung für die Oper Don Pasquale von Donizetti.</p>
    </div>

    <div class="galerie galerie--single">
      <Image src={imgDon1} alt="Don Pasquale, Mittelsächsisches Theater" />
      <Image src={imgDon2} alt="Don Pasquale – Detailaufnahme" loading="lazy" />
    </div>

    <div class="nav-links">
      <a href="/portfolio" class="back-link">← Zurück zum Portfolio</a>
    </div>
  </div>
</BaseLayout>

<style>
  .projekt-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-section) 8%;
  }

  .meta {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin: 0 0 1.5rem;
  }

  dt { font-weight: 600; color: var(--color-text-light); font-size: var(--text-sm); }
  dd { margin: 0; color: var(--color-text); font-size: var(--text-sm); }

  .meta p { color: var(--color-text); line-height: 1.7; margin: 0; }

  .galerie {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }

  .galerie img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
  }

  .back-link {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .back-link:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .galerie { grid-template-columns: 1fr; }
  }
</style>
