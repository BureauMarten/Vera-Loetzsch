---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import { Image } from 'astro:assets';
import Lightbox from '../../components/ui/Lightbox.astro';
import imgGrafik1 from '../../assets/images/Freie-Arbeiten-web-01.jpg';
import imgGrafik2 from '../../assets/images/Freie-Arbeiten-web-02.jpg';
---

<BaseLayout
  title="Grafiken – Vera Lötzsch"
  description="Freie grafische Arbeiten von Vera Lötzsch."
>
  <PageHeader
    title="Grafiken"
    breadcrumb={[
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Grafiken', href: '/projekte/grafiken' },
    ]}
  />

  <div class="projekt-content">
    <div class="meta">
      <dl>
        <dt>Kategorie</dt>
        <dd>Freie Arbeiten</dd>
      </dl>
    </div>

    <div class="galerie">
      <Image src={imgGrafik1} alt="Grafiken – freie Arbeit 1" />
      <Image src={imgGrafik2} alt="Grafiken – freie Arbeit 2" loading="lazy" />
    </div>

    <div class="nav-links">
      <a href="/portfolio" class="back-link">← Zurück zum Portfolio</a>
    </div>
  </div>
  <Lightbox />
</BaseLayout>

<style>
  .projekt-content { max-width: var(--max-width); margin: 0 auto; padding: var(--spacing-section) var(--padding-x); }
  .meta { max-width: 600px; margin-bottom: 3rem; }
  dl { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1.5rem; margin: 0; }
  dt { font-weight: 600; color: var(--color-text-light); font-size: var(--text-sm); }
  dd { margin: 0; color: var(--color-text); font-size: var(--text-sm); }
  .galerie { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 3rem; }
  .galerie img { width: 100%; height: auto; display: block; border-radius: var(--radius-sm); }
  .back-link { color: var(--color-primary); text-decoration: none; font-size: var(--text-sm); font-weight: 500; }
  .back-link:hover { text-decoration: underline; }
  @media (max-width: 600px) { .galerie { grid-template-columns: 1fr; } }
</style>
