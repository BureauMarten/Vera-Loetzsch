---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/layout/PageHeader.astro';
import { Image } from 'astro:assets';
import Lightbox from '../../components/ui/Lightbox.astro';
import imgNihilist from '../../assets/images/Freie-Arbeiten-web-05.jpg';
---

<BaseLayout
  title="Nihilist – Vera Lötzsch"
  description="Nihilist – Lithografie, 2017."
>
  <PageHeader
    title="Nihilist"
    breadcrumb={[
      { label: 'Portfolio', href: '/portfolio' },
      { label: 'Nihilist', href: '/projekte/nihilist' },
    ]}
  />

  <div class="projekt-content">
    <div class="meta">
      <dl>
        <dt>Kategorie</dt>
        <dd>Freie Arbeiten</dd>
        <dt>Technik</dt>
        <dd>Lithografie</dd>
        <dt>Jahr</dt>
        <dd>2017</dd>
      </dl>
    </div>

    <div class="galerie galerie--single">
      <Image src={imgNihilist} alt="Nihilist – Lithografie 2017" />
    </div>

    <div class="nav-links">
      <a href="/portfolio" class="back-link">← Zurück zum Portfolio</a>
    </div>
  </div>
  <Lightbox />
</BaseLayout>

<style>
  .projekt-content { max-width: var(--max-width); margin: 0 auto; padding: var(--spacing-section) var(--padding-x); }
  .meta { max-width: 600px; margin-bottom: 3rem; }
  dl { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1.5rem; margin: 0; }
  dt { font-weight: 600; color: var(--color-text-light); font-size: var(--text-sm); }
  dd { margin: 0; color: var(--color-text); font-size: var(--text-sm); }
  .galerie--single img { max-width: 600px; width: 100%; height: auto; display: block; border-radius: var(--radius-sm); margin-bottom: 3rem; }
  .back-link { color: var(--color-primary); text-decoration: none; font-size: var(--text-sm); font-weight: 500; }
  .back-link:hover { text-decoration: underline; }
</style>
